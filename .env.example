# Optional: live arrival predictions from the Ministry of Transport SIRI service.
# Obtain a user code by emailing a signed access form to ptsupport@mot.gov.il
# (see https://www.gov.il/he/Departments/General/real_time_information_siri).
# Without this, the app uses the open published schedule (Open Bus / Stride).
MOT_SIRI_API_KEY=

# Endpoint for the MoT SIRI Stop Monitoring service. Confirm the exact host/port
# with your onboarding email; this is the commonly used value.
MOT_SIRI_ENDPOINT=http://siri.motrealtime.co.il:8081/Siri/SiriServices
